PORT=3001
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Point this at llama.cpp, llama-cpp-python server, LM Studio, or any OpenAI-compatible local GGUF server.
LLAMA_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_MODEL=HauhauCS/Gemma-4-E4B-Uncensored-HauhauCS-Aggressive:Q4_K_P
LLAMA_API_KEY=local
LLAMA_REQUEST_TIMEOUT_MS=600000

# Local STT runtime. By default this is the same Python runtime that also exposes /v1/chat/completions.
STT_BASE_URL=http://127.0.0.1:8080
STT_REQUEST_TIMEOUT_MS=120000
STT_MAX_AUDIO_MB=25

# Translation defaults adapted from Boku-No-Translator.
LLAMA_TEMPERATURE=0.1
LLAMA_TOP_P=0.95
LLAMA_TOP_K=64
LLAMA_MAX_TOKENS=128
